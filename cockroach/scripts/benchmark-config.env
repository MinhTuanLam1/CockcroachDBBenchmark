# Shared TPC-C benchmark settings — 8 vCPU, 32GB RAM
# Sourced by setup.sh, benchmark.sh, chaos-kill.sh

BENCHMARK_WAREHOUSES=10
BENCHMARK_DURATION=20m
BENCHMARK_RAMP=30s
BENCHMARK_CONCURRENCY=100
# TPC-C thinking time (wait between transactions per official spec)
BENCHMARK_WAIT=true

CHAOS_WAREHOUSES=10
CHAOS_DURATION=20m
CHAOS_RAMP=30s
CHAOS_CONCURRENCY=100
CHAOS_WARMUP_SEC=45
CHAOS_NODE=cockroach3
CHAOS_WAIT=true

DB_URL="postgresql://root@cockroach1:26257?sslmode=disable"
